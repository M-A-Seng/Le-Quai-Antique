{
    "name": "le-quai-antique/website",
    "description": "Site vitrine du restaurant 'Le Quai Antique'",
    "type": "projet-scolaire",
    "version": "1.0.0",
    "require": {
        "php": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": ["app/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
        "App\\Tests\\": "tests/"
        },
        "files": ["app/helpers.php"]
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "13"
    }
}
