{
    "name": "le-quai-antique/website",
    "description": "Site vitrine du restaurant 'Le Quai Antique'",
    "type": "projet-scolaire",
    "version": "1.0.0",
    "require": {
        "php": "^8.5",
        "cloudinary/cloudinary_php": "^3.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
        "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "13"
    }
}
